package com.example.videojuegos

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material3.*
import androidx.compose.runtime.Composable
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import com.example.videojuegos.ui.theme.VideojuegosTheme

// 1. DATA CLASS
data class Game(
    val titulo: String,
    val plataforma: String,
    val imagen: String  // emoji como imagen simple
)

// 2. LISTA DE 10 JUEGOS
val listaJuegos = listOf(
    Game("The Legend of Zelda", "Nintendo Switch", "🗡️"),
    Game("God of War", "PlayStation 5", "⚔️"),
    Game("Halo Infinite", "Xbox Series X", "🔫"),
    Game("Minecraft", "PC", "⛏️"),
    Game("FIFA 25", "PlayStation 5", "⚽"),
    Game("Elden Ring", "PC", "🐉"),
    Game("Mario Kart 8", "Nintendo Switch", "🏎️"),
    Game("Call of Duty", "Xbox Series X", "🎮"),
    Game("Fortnite", "PC", "🏆"),
    Game("Cyberpunk 2077", "PlayStation 5", "🌆")
)

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            VideojuegosTheme {
                Surface(
                    modifier = Modifier.fillMaxSize(),
                    color = MaterialTheme.colorScheme.background
                ) {
                    PantallaJuegos()
                }
            }
        }
    }
}

// 3. PANTALLA PRINCIPAL CON LAZYCOLUMN
@Composable
fun PantallaJuegos() {
    Column(modifier = Modifier.fillMaxSize().padding(16.dp)) {
        Text(
            text = "🎮 Mis Juegos",
            fontSize = 28.sp,
            fontWeight = FontWeight.Bold,
            color = MaterialTheme.colorScheme.primary,
            modifier = Modifier.padding(bottom = 16.dp)
        )

        LazyColumn(verticalArrangement = Arrangement.spacedBy(12.dp)) {
            items(listaJuegos) { juego ->
                GameCard(juego = juego)
            }
        }
    }
}

// 4. CARD PERSONALIZADA
@Composable
fun GameCard(juego: Game) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        shape = RoundedCornerShape(16.dp),  // Shape personalizado
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.secondaryContainer
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 6.dp)
    ) {
        Row(
            modifier = Modifier.padding(16.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Imagen (emoji)
            Text(text = juego.imagen, fontSize = 40.sp)

            Spacer(modifier = Modifier.width(16.dp))

            Column {
                Text(
                    text = juego.titulo,
                    fontSize = 18.sp,
                    fontWeight = FontWeight.Bold,
                    color = MaterialTheme.colorScheme.onSecondaryContainer
                )
                Text(
                    text = juego.plataforma,
                    fontSize = 14.sp,
                    color = MaterialTheme.colorScheme.primary
                )
            }
        }
    }
}
